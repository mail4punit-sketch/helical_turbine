FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include        "include/initialConditions"

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform $turbulentOmega;

boundaryField
{
    in
    {
         type  fixedValue;
        value $internalField;
    }

    out
    {
        type            zeroGradient;
    }

    oversetSurface
    {
        type            overset;
        value           $internalField;

    }

    wing
    {
        type            omegaWallFunction;
        value           $internalField;
    }
   top
    {
       type            zeroGradient;
    }

}


